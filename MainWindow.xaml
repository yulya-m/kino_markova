<Window x:Class="Kino26_Markova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kino26_Markova"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" MinHeight="450" MinWidth="800">
    <Grid>
        <Button
            Click="Clubs"
            Height="25"
            Content="Клубы"
            VerticalAlignment="Top"
            Margin="10,10,0,0"
            HorizontalAlignment="Left"
            Width="100"
            Background="#FFFFD371"
            BorderBrush="#FFFFD371"
            Foreground="#FF231705"/>
        <Button
            Click="Users"
            Height="25"
            Content="Пользователи"
            VerticalAlignment="Top"
            Margin="115,10,0,0"
            HorizontalAlignment="Left"
            Width="100"
            Background="#FFFFD371"
            BorderBrush="#FFFFD371"
            Foreground="#FF231705"/>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="0,40,0,0"/>
    </Grid>
</Window>
