<Page x:Class="Kino26_Markova.Pages.Clubs.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kino26_Markova.Pages.Clubs"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Margin="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100px"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Image
        Width="80"
        Height="80"
        VerticalAlignment="Top"
        Margin="10" Source="/Images/icons8-монитор-100.png"/>
        <Button
        Click="AddClub"
        x:Name="BthAdd"
        Height="25"
        Content="Добавить"
        VerticalAlignment="Top"
        Margin="10,95,10,0"
        Background="#FFFFD371"
        BorderBrush="#FFFFD371"
        Foreground="#FF231705"/>
        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label
            Content="Наименование:"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Margin="10,10,0,0"/>
            <TextBox
            x:Name="Name"
            VerticalAlignment="Top"
            Margin="10,36,10,0"
            Height="25"
            VerticalContentAlignment="Center"/>
            <Label
            Content="Адрес:"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Margin="10,66,0,0"/>
            <TextBox
            x:Name="Address"
            VerticalAlignment="Top"
            Margin="10,92,10,0"
            Height="25"
            VerticalContentAlignment="Center"/>
            <Label
            Content="Время работы:"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Margin="10,10,0,0"
            Grid.Column="1"/>
            <TextBox
            x:Name="WorkTime"
            VerticalAlignment="Top"
            Margin="10,36,10,0"
            Height="81"
            VerticalContentAlignment="Center"
            Grid.Column="1"/>
        </Grid>
    </Grid>
</Page>
